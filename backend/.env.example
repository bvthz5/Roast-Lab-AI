# Application Settings
ENVIRONMENT=development
LOG_LEVEL=info

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="RoastLab AI"

# Database Configuration
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=roastlab
POSTGRES_PORT=5432
SQLALCHEMY_DATABASE_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Models Configuration (Local by default)
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL_NAME=BAAI/bge-large-en-v1.5

# Optional Third-Party Services
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
