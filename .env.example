# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=generate-a-secure-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@db:5432/roastlab
# DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/roastlab (Local Dev)

# Redis
REDIS_URL=redis://redis:6379/0
# REDIS_URL=redis://localhost:6379/0 (Local Dev)

# AI & Vector DB
QDRANT_URL=http://qdrant:6333
OLLAMA_BASE_URL=http://ollama:11434

# Security
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
